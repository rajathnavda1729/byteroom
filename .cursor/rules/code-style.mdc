### Hooks Pattern

```typescript
// hooks/useWebSocket.ts
import { useEffect, useRef, useCallback } from 'react';
import { useConnectionStore } from '@/stores/connectionStore';

interface UseWebSocketOptions {
  url: string;
  onMessage: (data: unknown) => void;
  reconnectAttempts?: number;
}

export function useWebSocket({ url, onMessage, reconnectAttempts = 5 }: UseWebSocketOptions) {
  const wsRef = useRef<WebSocket | null>(null);
  const { setConnected, setReconnecting } = useConnectionStore();

  const connect = useCallback(() => {
    // Implementation
  }, [url, onMessage]);

  const send = useCallback((data: unknown) => {
    if (wsRef.current?.readyState === WebSocket.OPEN) {
      wsRef.current.send(JSON.stringify(data));
    }
  }, []);

  useEffect(() => {
    connect();
    return () => {
      wsRef.current?.close();
    };
  }, [connect]);

  return { send };
}
```

### Zustand Store Pattern

```typescript
// stores/chatStore.ts
import { create } from 'zustand';
import { immer } from 'zustand/middleware/immer';
import type { Message, Chat } from '@/types';

interface ChatState {
  chats: Record<string, Chat>;
  messages: Record<string, Message[]>;
  activeChat: string | null;
}

interface ChatActions {
  setActiveChat: (chatId: string) => void;
  addMessage: (chatId: string, message: Message) => void;
  addOptimisticMessage: (chatId: string, message: Message) => void;
  confirmMessage: (tempId: string, confirmedMessage: Message) => void;
}

export const useChatStore = create<ChatState & ChatActions>()(
  immer((set) => ({
    chats: {},
    messages: {},
    activeChat: null,
    
    setActiveChat: (chatId) => set((state) => {
      state.activeChat = chatId;
    }),
    
    addMessage: (chatId, message) => set((state) => {
      if (!state.messages[chatId]) {
        state.messages[chatId] = [];
      }
      state.messages[chatId].push(message);
    }),
    
    addOptimisticMessage: (chatId, message) => set((state) => {
      if (!state.messages[chatId]) {
        state.messages[chatId] = [];
      }
      state.messages[chatId].push({ ...message, status: 'pending' });
    }),
    
    confirmMessage: (tempId, confirmedMessage) => set((state) => {
      // Find and replace optimistic message
    }),
  }))
);
```

### Type Definitions

```typescript
// types/index.ts
export type ContentType = 'markdown' | 'diagram_state' | 'image';
export type MessageStatus = 'pending' | 'sent' | 'delivered' | 'failed';

export interface Message {
  message_id: string;
  chat_id: string;
  sender_id: string;
  content_type: ContentType;
  content: string;
  timestamp: string;
  status?: MessageStatus;
}

export interface Chat {
  chat_id: string;
  name: string;
  type: 'direct' | 'group';
  members: string[];
  created_at: string;
}

export interface User {
  user_id: string;
  username: string;
  display_name: string;
  avatar_url?: string;
}

// WebSocket Events
export type WSEvent = 
  | { event: 'message.send'; data: Omit<Message, 'timestamp'> }
  | { event: 'message.ack'; data: { message_id: string; status: boolean } }
  | { event: 'message.new'; data: Message }
  | { event: 'user.typing'; data: { chat_id: string; user_id: string } };
```

