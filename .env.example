# Database
DB_USER=byteroom
DB_PASSWORD=changeme_strong_password
DB_NAME=byteroom
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable

# JWT
JWT_SECRET=changeme_at_least_32_chars_random_secret
JWT_EXPIRY_HOURS=24

# Server
PORT=8080
ENV=production

# S3 (optional — leave blank to disable image uploads)
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Frontend (Vite) — optional. Dev UI defaults to ws://127.0.0.1:8080 for WebSocket (see docs/local-testing-guide.md).
# VITE_WS_URL=wss://api.yourdomain.com
